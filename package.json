{
  "name": "vod-pipeline",
  "version": "0.1.0",
  "description": "AI-Assisted Video Editor for Twitch VODs",
  "main": "dist/src/electron/main.js",
  "type": "module",
  "engines": {
    "node": ">=22 <23"
  },
  "scripts": {
    "dev": "node ./scripts/dev.js",
    "setup:dev": "node ./scripts/ensure-electron.js && node ./scripts/ensure-better-sqlite3.js && node ./scripts/copy-database.js && node ./scripts/copy-preload.js",
    "dev:renderer": "vite",
    "dev:electron": "node ./scripts/dev-electron-supervisor.js",
    "dev:main": "node ./scripts/run-electron.js dist/src/electron/main.js",
    "doctor": "node ./scripts/doctor.mjs",
    "build": "pnpm build:renderer && pnpm build:electron",
    "build:renderer": "vite build",
    "build:electron": "tsc -p tsconfig.electron.json && node ./scripts/copy-database.js && node ./scripts/copy-preload.js",
    "dist": "pnpm build && electron-builder",
    "typecheck": "svelte-check --tsconfig ./tsconfig.json",
    "lint": "eslint .",
    "verify": "pnpm lint && pnpm typecheck && pnpm test:unit",
    "test": "pnpm test:unit",
    "test:unit": "vitest --run tests/unit",
    "test:integration": "vitest --run tests/integration",
    "test:all": "vitest --run",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage --run tests/unit",
    "postinstall": "node ./scripts/install-ffmpeg.js && node ./scripts/install-audiowaveform.js"
  },
  "keywords": [
    "video",
    "editor",
    "electron",
    "twitch",
    "vod",
    "ai"
  ],
  "author": "",
  "license": "ISC",
  "packageManager": "pnpm@10.26.0",
  "dependencies": {
    "@langchain/anthropic": "^1.3.12",
    "@langchain/core": "^1.1.17",
    "@langchain/google-genai": "^2.1.13",
    "@langchain/langgraph": "^1.1.2",
    "@langchain/langgraph-checkpoint-sqlite": "^1.0.0",
    "@langchain/openai": "^1.2.3",
    "better-sqlite3": "^12.6.2",
    "dotenv": "^17.2.3",
    "lucide-svelte": "^1.0.1",
    "marked": "^18.0.1",
    "remark-gfm": "^4.0.1",
    "svelte": "^5.48.3",
    "svelte-markdown": "^0.4.1",
    "uuid": "^13.0.0",
    "wavesurfer.js": "^7.12.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.26.0",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.1.0",
    "adm-zip": "^0.5.16",
    "chokidar": "^4.0.3",
    "concurrently": "^9.2.1",
    "electron": "^40.0.0",
    "electron-builder": "^26.4.0",
    "eslint": "^9.26.0",
    "eslint-plugin-svelte": "^2.46.1",
    "globals": "^15.15.0",
    "svelte-check": "^4.3.5",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.31.1",
    "vite": "^7.3.1",
    "vitest": "^3.0.0",
    "wait-on": "^8.0.5"
  }
}
