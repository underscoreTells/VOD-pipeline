{
  "appId": "com.vod-pipeline.app",
  "productName": "VOD Pipeline",
  "directories": {
    "output": "release"
  },
  "files": [
    "dist/**",
    "package.json",
    "database/**"
  ],
  "asar": true,
  "asarUnpack": [
    "node_modules/better-sqlite3/**/*"
  ],
  "beforePack": "./scripts/prepare-native-binaries.js",
  "win": {
    "target": ["nsis"],
    "icon": "assets/icon.ico",
    "extraResources": [{
      "from": "binaries/win32/${arch}/",
      "to": "binaries/win32/${arch}/",
      "filter": ["ffmpeg.exe", "ffprobe.exe", "audiowaveform.exe"]
    }]
  },
  "mac": {
    "target": ["dmg"],
    "icon": "assets/icon.icns",
    "category": "public.app-category.video",
    "hardenedRuntime": true,
    "gatekeeperAssess": false,
    "extraResources": [{
      "from": "binaries/darwin/${arch}/",
      "to": "binaries/darwin/${arch}/",
      "filter": ["ffmpeg", "ffprobe"]
    }]
  },
  "linux": {
    "target": ["AppImage"],
    "icon": "assets/icon.png",
    "category": "Video",
    "extraResources": [{
      "from": "binaries/linux/${arch}/",
      "to": "binaries/linux/${arch}/",
      "filter": ["ffmpeg", "ffprobe"]
    }]
  }
}
